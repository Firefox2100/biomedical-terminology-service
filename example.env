BTS_PROCESS_LIMIT=4
BTS_AUTO_COMPLETE_MIN_LENGTH=3

BTS_LOGGING_LEVEL=INFO
BTS_SECRET_KEY=secret-key
BTS_SERVER_HMAC_KEY=your-hmac-key
BTS_USE_HTTPS=false
BTS_ENABLE_METRICS=true
BTS_ENABLE_ERROR_REPORTING=false
BTS_ENABLE_PROFILING=false
BTS_SENTRY_DSN=
BTS_GOOGLE_SITE_VERIFICATION_ID=
BTS_DATA_DIR=data
BTS_SERVICE_ROOT_PATH=
BTS_OPENAPI_URL=/openapi.json
BTS_DOCS_URL=/docs
BTS_REDOC_URL=/redoc
BTS_FHIR_CANONICAL_URL=https://your.deployment.com/fhir
BTS_ENVIRONMENT=dev
BTS_CELERY_BROKER=redis://localhost:6379/1
BTS_CELERY_BACKEND=redis://localhost:6379/2

BTS_DOC_DATABASE_DRIVER=mongo
BTS_MONGODB_HOST=localhost
BTS_MONGODB_PORT=27017
BTS_MONGODB_DB_NAME=bts
BTS_MONGODB_USERNAME=bts_user
BTS_MONGODB_PASSWORD=password
BTS_MONGODB_AUTH_SOURCE=admin

# Only used when BTS_DOC_DATABASE_DRIVER=sql. Requires the "sql" extra and, depending on the
# dialect, a separate async driver package (e.g. asyncpg, aiomysql/asyncmy, or aiosqlite).
BTS_SQL_DB_URL=sqlite+aiosqlite:///./bts.sqlite3
BTS_SQL_BATCH_SIZE=5000

BTS_GRAPH_DATABASE_DRIVER=neo4j
BTS_NEO4J_URI=neo4j://localhost:7687
BTS_NEO4J_DB_NAME=neo4j
BTS_NEO4J_USERNAME=neo4j
BTS_NEO4J_PASSWORD=password

BTS_CACHE_DRIVER=redis
BTS_REDIS_HOST=localhost
BTS_REDIS_PORT=6379
BTS_REDIS_DB=0
BTS_CACHE_HARD_TTL_MULTIPLIER=7
BTS_CACHE_REBUILD_LOCK_TTL=3600

BTS_BIOPORTAL_API_KEY=your-bioportal-api-key
BTS_NHS_TRUD_API_KEY=your-nhs-trud-api-key
BTS_NIH_UMLS_API_KEY=your-nih-umls-api-key

BTS_TRANSFORMER_MODEL_NAME="BAAI/bge-base-en-v1.5"
BTS_EMBEDDING_PROCESS_LIMIT=1
BTS_EMBEDDING_BATCH_SIZE=32
BTS_TORCH_DEVICE=cpu
BTS_GNN_EPOCHS=100
BTS_GNN_HIDDEN_DIM=256
BTS_GNN_OUTPUT_DIM=256
BTS_GNN_LEARNING_RATE=0.001
BTS_VECTOR_DATABASE_DRIVER=qdrant
BTS_QDRANT_LOCATION="http://localhost:6333"

BTS_VERBOSE_PRINT=false
BTS_DISABLE_PROGRESS_BAR=false
